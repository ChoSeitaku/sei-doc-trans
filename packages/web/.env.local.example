# --- Mock mode ---
# When NEXT_PUBLIC_USE_MOCK=1 the Next.js Route Handlers under /app/api/* serve
# fixture data instead of proxying to a real backend. This is the default for
# local development so the UI runs with zero external dependencies.
NEXT_PUBLIC_USE_MOCK=1

# --- Real backend (optional) ---
# Once a backend exists, set this to its base URL and flip USE_MOCK to 0.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- GitHub App (only needed in non-mock mode) ---
# These never reach the browser; they are read by the future backend.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
