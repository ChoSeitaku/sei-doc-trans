{
  "name": "@github-global/providers",
  "version": "0.1.0",
  "private": false,
  "description": "LLM provider adapters for github-global",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@github-global/core": "workspace:*",
    "openai": "^4.70.0",
    "@anthropic-ai/sdk": "^0.30.0"
  }
}
